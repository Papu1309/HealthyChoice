<Window x:Class="HealthyChoice.Views.AddToCartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление в корзину" Height="450" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Height="100">
            <TextBlock Text="🛒 Добавление товара в корзину" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardStyle}" Margin="20" Padding="20">
                <StackPanel>
                    <!-- Информация о товаре -->
                    <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,20" Background="#F9F9F9">
                        <StackPanel>
                            <TextBlock x:Name="txtProductName" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource PrimaryColor}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <TextBlock x:Name="txtProductPrice" 
                                       FontSize="14" 
                                       Foreground="Gray"
                                       TextAlignment="Center"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtProductStock" 
                                       FontSize="12" 
                                       Foreground="Gray"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Выбор количества -->
                    <TextBlock Text="Количество:" 
                               FontSize="14" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" 
                                Content="-" 
                                Width="40" 
                                Height="40"
                                FontSize="20"
                                FontWeight="Bold"
                                Click="DecreaseQuantity_Click"
                                Style="{StaticResource PrimaryButton}"
                                Padding="0"/>

                        <TextBox x:Name="txtQuantity" 
                                 Grid.Column="1"
                                 Style="{StaticResource TextBoxStyle}"
                                 Text="1"
                                 TextAlignment="Center"
                                 FontSize="16"
                                 FontWeight="Bold"
                                 Height="40"
                                 Margin="10,0"
                                 PreviewTextInput="Quantity_PreviewTextInput"
                                 TextChanged="Quantity_TextChanged"/>

                        <Button Grid.Column="2" 
                                Content="+" 
                                Width="40" 
                                Height="40"
                                FontSize="20"
                                FontWeight="Bold"
                                Click="IncreaseQuantity_Click"
                                Style="{StaticResource PrimaryButton}"
                                Padding="0"/>
                    </Grid>

                    <!-- Итоговая сумма -->
                    <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,20" Background="#E8F5E9">
                        <StackPanel>
                            <TextBlock Text="Итого:" 
                                       FontSize="12" 
                                       Foreground="Gray"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtTotal" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource PrimaryColor}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Дополнительные опции -->
                    <TextBlock Text="Дополнительно:" 
                               FontSize="14" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <CheckBox x:Name="chkGiftWrap" 
                              Content="🎁 Подарочная упаковка (+150 ₽)" 
                              Margin="0,0,0,10"
                              Checked="GiftWrap_Changed"
                              Unchecked="GiftWrap_Changed"/>

                    <CheckBox x:Name="chkExpress" 
                              Content="⚡ Экспресс-доставка (+300 ₽)" 
                              Margin="0,0,0,10"
                              Checked="Express_Changed"
                              Unchecked="Express_Changed"/>

                    <CheckBox x:Name="chkInsurance" 
                              Content="🛡️ Страхование товара (+200 ₽)" 
                              Margin="0,0,0,20"
                              Checked="Insurance_Changed"
                              Unchecked="Insurance_Changed"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="✅ Добавить в корзину" 
                                Click="AddToCart_Click"
                                Style="{StaticResource PrimaryButton}"
                                Width="210"
                                Margin="5"/>
                        <Button Content="❌ Отмена" 
                                Click="Cancel_Click"
                                Background="Gray"
                                Foreground="White"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="20,10"
                                Margin="5"
                                Cursor="Hand"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Gray"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="5" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#555555"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="txtError" 
                               Foreground="Red" 
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="5,10,5,0"
                               Visibility="Collapsed"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>