<Window x:Class="HealthyChoice.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация - Здоровый Выбор" Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Height="120">
            <StackPanel VerticalAlignment="Center" Margin="20">
                <TextBlock Text="📝 Регистрация нового пользователя" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Заполните все поля для создания аккаунта" 
                           FontSize="11" 
                           Foreground="White" 
                           Opacity="0.9"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource CardStyle}" Margin="20" Padding="20">
                <StackPanel>
                    <!-- Логин -->
                    <TextBlock Text="👤 Логин*" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtUsername" 
                             Style="{StaticResource TextBoxStyle}"
                             Height="35"
                             Margin="0,0,0,15"/>

                    <!-- Пароль -->
                    <TextBlock Text="🔒 Пароль*" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword" 
                                 Style="{StaticResource PasswordBoxStyle}"
                                 Height="35"
                                 Margin="0,0,0,15"/>

                    <!-- Подтверждение пароля -->
                    <TextBlock Text="🔒 Подтверждение пароля*" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtConfirmPassword" 
                                 Style="{StaticResource PasswordBoxStyle}"
                                 Height="35"
                                 Margin="0,0,0,15"/>

                    <!-- ФИО -->
                    <TextBlock Text="👤 ФИО*" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtFullName" 
                             Style="{StaticResource TextBoxStyle}"
                             Height="35"
                             Margin="0,0,0,15"/>

                    <!-- Email -->
                    <TextBlock Text="📧 Email*" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtEmail" 
                             Style="{StaticResource TextBoxStyle}"
                             Height="35"
                             Margin="0,0,0,15"/>

                    <!-- Телефон -->
                    <TextBlock Text="📱 Телефон*" 
                               FontSize="13" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPhone" 
                             Style="{StaticResource TextBoxStyle}"
                             Height="35"
                             Margin="0,0,0,15"
                             PreviewTextInput="Phone_PreviewTextInput"/>

                    <!-- Информация о полях -->
                    <TextBlock Text="* - обязательные поля" 
                               FontSize="10" 
                               Foreground="Gray"
                               Margin="0,0,0,15"/>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="✅ Зарегистрироваться" 
                                Click="Register_Click"
                                Style="{StaticResource PrimaryButton}"
                                Width="220"
                                Margin="5"/>
                        <Button Content="❌ Отмена" 
                                Click="Cancel_Click"
                                Background="Gray"
                                Foreground="White"
                                FontSize="14"
                                FontWeight="Bold"
                                Padding="20,10"
                                Margin="5"
                                Cursor="Hand"
                                BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Gray"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="5" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#555555"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <TextBlock x:Name="txtError" 
                               Foreground="Red" 
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="5,10,5,0"
                               Visibility="Collapsed"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>