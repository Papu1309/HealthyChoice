<Window x:Class="HealthyChoice.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Здоровый Выбор" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Grid Margin="0,0,0,-16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Height="120">
            <StackPanel VerticalAlignment="Center" Margin="20">
                <TextBlock Text="Здоровый Выбор" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Автоматизированная система учета клиентов" 
                           FontSize="12" 
                           Foreground="White" 
                           Opacity="0.9"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="20" Padding="20">
            <StackPanel Margin="0,0,0,-20">
                <TextBlock Text="Вход в систему" 
                           Style="{StaticResource PageTitle}"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Логин" Margin="5,0,0,5"/>
                <TextBox x:Name="txtUsername" Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Пароль" Margin="5,10,0,5"/>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource PasswordBoxStyle}"/>

                <Button Content="Войти" 
                        Style="{StaticResource PrimaryButton}"
                        Click="Login_Click"
                        Margin="0,20,0,10"/>

                <Button Content="Регистрация" 
                        Background="Transparent"
                        Foreground="{StaticResource PrimaryColor}"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Register_Click"
                        Margin="0,5,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#1B5E20"/>
                                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock x:Name="txtError" 
                           Foreground="Red" 
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="5,10,5,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>